# Plaud API credentials
# See SKILL.md for setup tutorial

# Your bearer token from localStorage.tokenstr
# Include the "bearer " prefix
PLAUD_TOKEN=bearer eyJ...your_full_token_here...

# API domain from localStorage.plaud_user_api_domain
# Region-specific: EU = api-euc1, US may differ
PLAUD_API_DOMAIN=https://api-euc1.plaud.ai
